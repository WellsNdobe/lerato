{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Lerato",
  "scopeName": "source.lerato",
  "patterns": [
    {
      "include": "#strings"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#booleans"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#builtins"
    },
    {
      "include": "#function-definition"
    },
    {
      "include": "#function-call"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.lerato",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.lerato",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.lerato",
          "match": "\\b(?:ge|goba|gefela|gona|feleletsa|tiro|busa|tsenya)\\b"
        }
      ]
    },
    "booleans": {
      "patterns": [
        {
          "name": "constant.language.boolean.lerato",
          "match": "\\b(?:nnete|maaka)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.lerato",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.builtin.lerato",
          "match": "\\b(?:bontsha|amogela)\\b(?=\\s*\\()"
        }
      ]
    },
    "function-definition": {
      "patterns": [
        {
          "match": "\\b(tiro)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.control.lerato"
            },
            "2": {
              "name": "entity.name.function.lerato"
            }
          }
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "name": "entity.name.function.lerato",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\b(?=\\s*\\()"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.lerato",
          "match": "==|!=|>=|<=|=|>|<|\\+|-|\\*|/"
        }
      ]
    }
  }
}
